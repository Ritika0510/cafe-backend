# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/brewed_and_co
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/brewed_and_co

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer via Gmail) ──────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_cafe_email@gmail.com
EMAIL_PASS=your_gmail_app_password   # Use Gmail App Password (not your real password)
EMAIL_FROM="Brewed & Co. ☕ <your_cafe_email@gmail.com>"

# ── Frontend URL (for CORS) ───────────────────────────
CLIENT_URL=http://localhost:3000
